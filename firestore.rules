rules_version = '2';
// See docs/FIRESTORE_CONFIG_VERIFICATION.md for details on security rules and admin access.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    // 組織（エンタープライズ）: orgId / orgRole は Cloud Functions が custom claim に付与する。
    // 書き込みはすべて callable(admin SDK) 経由のため、ここでは所属チェック（閲覧）のみ定義する。
    function isOrgMember(orgId) {
      return isAuthenticated() && request.auth.token.orgId == orgId;
    }
    function isBookOwner(bookId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/books/$(bookId)).data.userId == request.auth.uid;
    }
    function onlyAdminReviewFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "adminTextQualityScore",
        "adminImageQualityScore",
        "adminCharacterConsistencyScore",
        "adminStorySatisfactionScore",
        "adminMemo",
        "adminReviewedAt",
        "adminReviewedBy",
        "adminQualityScore",
        "adminImageConsistencyScore",
        "latestQualityReviewId",
        "qualityReviewStatus",
        "storyQualityScore",
        "illustrationQualityScore",
        "characterConsistencyScore",
        "personalizationScore",
        "safetyScore",
        "overallQualityScore",
        "qualityReviewedAt",
        "qualityReviewedAtMs",
        "qualityReviewerType"
      ]);
    }

    // 課金・エンタイトルメント系フィールドは Admin SDK（Stripe webhook / 運用スクリプト）と
    // 管理者のみが変更できる。オーナーが自分のドキュメントから直接これらを書き換えて
    // プラン昇格・クォータ回避・クレジット自己付与する権限昇格を防ぐ。
    function ownerCannotChangeEntitlements() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "plan", "productPlan", "planOverride", "generationOverride",
        "singleBookCredits", "singlePurchaseCredits",
        "stripeCustomerId", "stripeSubscriptionId", "monthlyGenerationCount"
      ]);
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      // 新規ユーザーは無料・クォータ0・エンタイトルメント未設定のみ作成可（サインアップ payload に一致）。
      allow create: if isOwner(userId)
        && request.resource.data.plan == "free"
        && request.resource.data.get("monthlyGenerationCount", 0) == 0
        && !request.resource.data.keys().hasAny([
             "productPlan", "planOverride", "generationOverride",
             "singleBookCredits", "singlePurchaseCredits",
             "stripeCustomerId", "stripeSubscriptionId"
           ]);
      allow update: if isAdmin() || (isOwner(userId) && ownerCannotChangeEntitlements());
      allow delete: if false;

      match /children/{childId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isAdmin() || isOwner(userId);
        allow delete: if false;

        match /avatarGenerations/{generationId} {
          allow read: if isAdmin() || isOwner(userId);
          allow update: if isOwner(userId);
          allow create, delete: if false;
        }
      }

      match /usage/{yearMonth} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if false;
      }

      // 保存した生成設定テンプレート（オーナーのみ読み書き）。課金・権限には影響しない。
      match /savedTemplates/{templateId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      // 生成完了プッシュ通知の FCM トークン（オーナーのみ読み書き）。
      // 送信は Cloud Functions（admin SDK）が行う。課金・権限には影響しない。
      match /fcmTokens/{tokenId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /books/{bookId} {
      allow read: if isAdmin()
               || (isAuthenticated() && resource.data.userId == request.auth.uid)
               || resource.data.public == true
               || (resource.data.orgId != null && isOrgMember(resource.data.orgId));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() && onlyAdminReviewFieldsChanged();
      allow update: if isAuthenticated()
               && resource.data.userId == request.auth.uid
               && request.resource.data.diff(resource.data).changedKeys().hasOnly(["seriesId", "updatedAt", "updatedAtMs", "public", "favorite", "giftMessage"]);
      allow delete: if false;

      match /pages/{pageId} {
        allow read: if isAdmin() || isBookOwner(bookId)
                 || get(/databases/$(database)/documents/books/$(bookId)).data.public == true
                 || (get(/databases/$(database)/documents/books/$(bookId)).data.orgId != null
                     && isOrgMember(get(/databases/$(database)/documents/books/$(bookId)).data.orgId));
        allow write: if false;

        // Regeneration history – written by Cloud Functions, read-only for admin
        match /regenerationHistory/{attemptId} {
          allow read: if isAdmin();
          allow write: if false;
        }
      }

      match /feedback/{feedbackId} {
        allow read: if isAdmin() || isBookOwner(bookId);
        allow create, update: if isBookOwner(bookId);
        allow delete: if false;
      }

      match /qualityReviews/{reviewId} {
        allow read: if isAdmin();
        allow create: if isAdmin()
          && request.resource.data.bookId == bookId
          && request.resource.data.reviewerId == request.auth.uid
          && request.resource.data.reviewerType == "human"
          && request.resource.data.storyScore >= 1 && request.resource.data.storyScore <= 5
          && request.resource.data.illustrationScore >= 1 && request.resource.data.illustrationScore <= 5
          && request.resource.data.characterConsistencyScore >= 1 && request.resource.data.characterConsistencyScore <= 5
          && request.resource.data.personalizationScore >= 1 && request.resource.data.personalizationScore <= 5
          && request.resource.data.safetyScore >= 1 && request.resource.data.safetyScore <= 5
          && request.resource.data.status in ["reviewed", "needs_fix", "approved"];
        allow update, delete: if false;
      }
    }

    match /childAvatarGenerationJobs/{jobId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /companionImageJobs/{jobId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /companions/{companionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /series/{seriesId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // 組織（エンタープライズ）: 作成・参加・メンバー管理はすべて Cloud Functions
    // (admin SDK) 経由。クライアントからの直接書き込みは禁止し、閲覧のみ許可する。
    match /organizations/{orgId} {
      allow read: if isAdmin() || isOrgMember(orgId);
      allow write: if false;

      match /members/{memberUid} {
        allow read: if isAdmin() || isOrgMember(orgId);
        allow write: if false;
      }

      // 組織の月次使用量（E3 一括生成カウント）: メンバーは閲覧のみ。書込は callable。
      match /usage/{yearMonth} {
        allow read: if isAdmin() || isOrgMember(orgId);
        allow write: if false;
      }

      // クラス・園児名簿（E2）: 同じ組織のメンバーが CRUD 可能。他組織は不可視。
      match /classes/{classId} {
        allow read: if isAdmin() || isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);

        match /students/{studentId} {
          allow read: if isAdmin() || isOrgMember(orgId);
          allow create, update, delete: if isOrgMember(orgId);
        }
      }
    }

    match /companions/{companionId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /categoryGroups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /adminMetrics/{docId} {
      allow read: if isAdmin();
      allow write: if false;

      match /items/{itemId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      match /runs/{runId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /qualityTasks/{taskId} {
      function onlyQualityTaskUpdateFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "checklist",
          "assignedTo",
          "resolvedBy",
          "resolvedAt",
          "resolvedAtMs",
          "resolutionNote",
          "updatedAt",
          "updatedAtMs"
        ]);
      }

      function isValidQualityTaskUpdate() {
        return request.resource.data.status in [
          "open",
          "in_progress",
          "resolved",
          "wont_fix"
        ]
        && request.resource.data.updatedAtMs is number
        && request.resource.data.checklist is list;
      }

      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.bookId is string
        && request.resource.data.intent in [
          "prepare_story_rewrite",
          "review_image_regeneration",
          "review_character_consistency",
          "review_personalization_inputs",
          "require_human_safety_review",
          "confirm_approval"
        ]
        && request.resource.data.status == "open"
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAdmin()
        && onlyQualityTaskUpdateFieldsChanged()
        && isValidQualityTaskUpdate();

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

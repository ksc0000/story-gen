{
  "name": "story-gen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "node scripts/clean-build.mjs",
    "guard:hygiene": "node scripts/check-hygiene.mjs",
    "check:public-assets": "node scripts/check-public-assets.mjs",
    "report:generation-slo": "node scripts/report-generation-slo.mjs",
    "report:generation-slo:self-test": "node scripts/report-generation-slo.mjs --self-test",
    "test:generation-guards": "cd functions && npx vitest run test/candidate-gate.test.ts test/generation-event-logger.test.ts",
    "check:phase2": "npm run guard:hygiene && npm run report:generation-slo:self-test && npm run test:generation-guards",
    "logs:generation-query": "node scripts/print-generation-log-query.mjs",
    "smoke:create-template-books": "node scripts/create-template-smoke-books.js",
    "smoke:create-nonfixed-book": "node scripts/create-nonfixed-smoke-book.js",
    "smoke:monitor": "node scripts/monitor-smoke-book.js",
    "smoke:inspect": "node scripts/inspect-smoke-book.js",
    "smoke:upload-reference": "node scripts/setup-smoke-reference.js",
    "template:sync:check": "node scripts/sync-fixed-template-seeds.js",
    "template:sync:write": "node scripts/sync-fixed-template-seeds.js --write",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "deploy:hosting": "npm run build:clean && firebase deploy --only hosting",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.8.0",
    "next": "^15.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^23.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.0.0"
  }
}
